# R26-SE-031-V2 — Centralized Environment Configuration
# -------------------------------------------------------
# IMPORTANT: Do NOT commit this file to version control.
# Add .env to .gitignore.

# ── MongoDB Atlas ──────────────────────────────────────
MONGO_URI=mongodb+srv://kavindugunasena_db_user:2Vp8ipkprifuEH8t@cluster0.ypxuqen.mongodb.net/
MONGO_DB_NAME=dyslexia_platform

# ── Service Ports (v2 — separate from existing v1 services) ───────────────
C1_PORT=8011
C2_PORT=8014
C3_PORT=8012
C4_PORT=8013

# ── Service Base URLs (for inter-service calls) ──────────────────────────
C1_BASE_URL=http://localhost:8011
C2_BASE_URL=http://localhost:8014
C3_BASE_URL=http://localhost:8012
C4_BASE_URL=http://localhost:8013

# ── SQLite paths (50% milestone — before MongoDB migration) ──────────────
C1_SQLITE_PATH=./db/monitoring.db
C2_SQLITE_PATH=./db/visual.db
C3_SQLITE_PATH=./db/content.db
C4_SQLITE_PATH=./db/intervention.db

# ── C1 CBME — Feature thresholds (research-calibrated) ──────────────────
# Rayner (2001): >2000ms hesitation = decoding difficulty
HESITATION_THRESHOLD_MS=2000
# Fuchs et al. (2001): >400ms inter-word pause = fluency difficulty
PAUSE_THRESHOLD_MS=400
# Audio energy threshold for on-device syllable detection
AUDIO_ENERGY_THRESHOLD=0.02
# Kalman Filter process noise covariance
KALMAN_Q=0.001

# ── C1 CBME — MBSV thresholds ────────────────────────────────────────────
PHONOLOGICAL_STRAIN_TRIGGER=0.45
VISUAL_STRAIN_TRIGGER=0.60
ENGAGEMENT_LOW_THRESHOLD=0.30
FATIGUE_OVERRIDE_THRESHOLD=0.70

# ── C2 AVLI — LinUCB ─────────────────────────────────────────────────────
LINUCB_ALPHA=0.1
LINUCB_NUM_ARMS=8
LINUCB_CONTEXT_DIM=7

# ── C3 PLCE — BKT parameters ─────────────────────────────────────────────
BKT_P_INIT=0.3
BKT_P_LEARN=0.1
BKT_P_SLIP=0.1
BKT_P_GUESS=0.2
BKT_MASTERY_THRESHOLD=0.80
BKT_ZPD_LOWER=0.45
BKT_ZPD_UPPER=0.80

# ── C4 IIGE — SM-2 ───────────────────────────────────────────────────────
SM2_MIN_EASINESS_FACTOR=1.3
SM2_INITIAL_EASINESS_FACTOR=2.5

# ── C4 IIGE — RTI escalation ─────────────────────────────────────────────
RTI_TIER3_FAILURE_COUNT=3

# ── Logging ──────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
