# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
.eggs/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- Runtime caches (regenerated by the service) ---
# gTTS Sinhala/Tamil mp3s, recreated on first request.
audio_cache/*.mp3
# Keep the directory so the app can write into it.
!audio_cache/.gitkeep

# --- Local databases / dev data ---
# Local SQLite state — keep template, ignore live data.
# c4_state.db is dev-only state; uncomment the next line if you don't want it tracked.
# c4_state.db

# --- IDE / OS noise ---
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db
